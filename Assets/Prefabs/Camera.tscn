[node name="Label" type="Label" parent="CanvasLayer2/Control" unique_id=1471091441]
layout_mode = 0
offset_left = 730.0
offset_top = 113.0
offset_right = 1330.0
offset_bottom = 884.0
text = "Dear Alice,

Thank you for taking over the
apothecary for me. I know it is 
your first day. 

Read the book. (Press J)

It'll tell you what you 
need to know.

Many are getting sick.
The magic isn't working right.
You need to fix them. 
I believe in you. 

Signed,
Grandpappy"
label_settings = SubResource("LabelSettings_1t4mh")

[node name="Label2" type="Label" parent="CanvasLayer2/Control" unique_id=633784408]
visible = false
