offset_top = 113.0
offset_right = 1378.0
offset_bottom = 884.0
text = "Controls:

J = Read recipe book/Take item
       from crates, boiler or pestle/
       Add items to boiler or pestle/
       Dispose of rubbish.

K = Take patient order/Give patient
        antidote/Boil or grind items/

Enter = Advance to next day."
label_settings = SubResource("LabelSettings_1t4mh")

